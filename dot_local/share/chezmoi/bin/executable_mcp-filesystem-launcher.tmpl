#!/usr/bin/env bash
# MCP Filesystem Launcher (Chezmoi-managed)
# Provides controlled filesystem access via whitelist policy
#
# Usage: mcp-filesystem-launcher [additional_paths...]
#
# Obsidian vault: Chezmoi data ai.obsidian_vault_path (.chezmoi.toml or ~/.config/chezmoi/chezmoi.toml).

set -euo pipefail

ALLOWED_ROOTS=(
    "{{ .chezmoi.sourceDir }}"
    "{{ .chezmoi.homeDir }}/proyectos"
    "{{ .chezmoi.homeDir }}/.config"
    "{{ .ai.obsidian_vault_path }}"
)

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "MCP Filesystem Launcher"
    echo ""
    echo "Usage: $0 [additional_paths...]"
    echo ""
    echo "Allowed roots (always included):"
    for root in "${ALLOWED_ROOTS[@]}"; do
        echo "  - $root"
    done
    exit 0
fi

ALL_PATHS=("${ALLOWED_ROOTS[@]}")

for arg in "$@"; do
    abs_path=$(realpath -L "$arg" 2>/dev/null) || true
    if [[ -z "$abs_path" ]]; then
        echo "WARNING: Cannot resolve path '$arg' - not adding to allowed paths" >&2
        continue
    fi
    is_allowed=false
    for root in "${ALLOWED_ROOTS[@]}"; do
        if [[ "$abs_path" == "$root" || "$abs_path" == "$root"/* ]]; then
            is_allowed=true
            break
        fi
    done
    if [[ "$is_allowed" == true ]]; then
        path_already_added=false
        for existing_path in "${ALL_PATHS[@]}"; do
            if [[ "$existing_path" == "$abs_path" ]]; then
                path_already_added=true
                break
            fi
        done

        if [[ "$path_already_added" == false ]]; then
            ALL_PATHS+=("$abs_path")
        fi
    else
        echo "WARNING: Path '$abs_path' (from '$arg') is not within allowed roots, ignoring" >&2
    fi
done

exec npx -y "@modelcontextprotocol/server-filesystem" "${ALL_PATHS[@]}"
