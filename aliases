alias gnx-serve='gitnexus serve'                       # Iniciar servidor GitNexus local

_gnx_analyze_with_managed_node() {
  local runtime_lib="${DOTFILES_DIR:-$HOME/dotfiles}/scripts/update/lib/node_runtime.sh"
  local npm_prefix="${NPM_CONFIG_PREFIX:-${DOTFILES_NPM_PREFIX:-$HOME/.npm-global}}"
  local original_path="$PATH"
  local gitnexus_bin="" overlay="" exit_code=0

  if command -v gitnexus >/dev/null 2>&1; then
    gitnexus_bin="gitnexus"
  elif [ -x "$npm_prefix/bin/gitnexus" ]; then
    gitnexus_bin="$npm_prefix/bin/gitnexus"
  else
    echo "❌ GitNexus no está instalado"
    echo "   Ejecuta: ~/dotfiles/scripts/install-gitnexus.sh"
    return 1
  fi

  if [ ! -r "$runtime_lib" ]; then
    echo "⚠️  No se pudo cargar el helper de Node gestionado"
    echo "   Ejecuta: make update-check"
    return 1
  fi

  if [ -n "${ZSH_VERSION:-}" ]; then
    setopt local_options no_aliases
  fi
  source "$runtime_lib"
  node_runtime_probe

  if [ "$NODE_RUNTIME_EFFECTIVE_OK" -eq 1 ]; then
    "$gitnexus_bin" analyze "$@"
    return $?
  fi

  if [ "$NODE_RUNTIME_MANAGED_OK" -ne 1 ]; then
    echo "❌ Node.js efectivo no cumple >=${NODE_RUNTIME_MIN_MAJOR} y no hay Node gestionado compatible"
    echo "   Ejecuta: make update-check"
    return 1
  fi

  overlay="$(node_runtime_create_overlay "${TMPDIR:-/tmp}" "$NODE_RUNTIME_MANAGED_PATH")" || return 1
  PATH="$(node_runtime_controlled_path "$overlay" "$npm_prefix" "$original_path")"
  export PATH

  "$gitnexus_bin" analyze "$@"
  exit_code=$?

  PATH="$original_path"
  export PATH
  node_runtime_cleanup_overlay "$overlay"
  return "$exit_code"
}

# Función para analizar el repositorio actual
gnx-analyze-here() {
  if [ -d ".git" ]; then
    echo "🔍 Analizando repositorio actual con GitNexus..."
    _gnx_analyze_with_managed_node "$@"
  else
    echo "❌ No estás en un repositorio Git"
    return 1
  fi
}

# Función para generar wiki en docs/wiki/
gnx-wiki-here() {
  # Detectar raíz del repo
  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
  
  if [ -z "$repo_root" ]; then
    echo "❌ No estás en un repositorio Git"
    return 1
  fi
  
  # Cambiar a la raíz del repo
  cd "$repo_root"
  
  # Verificar que gitnexus está instalado
  if ! command -v gitnexus >/dev/null 2>&1; then
    echo "❌ GitNexus no está instalado"
    echo "   Ejecuta: ~/dotfiles/scripts/install-gitnexus.sh"
    return 1
  fi
  
  # Verificar índice o crearlo
  if ! gitnexus status >/dev/null 2>&1; then
    echo "🔍 Indexando repositorio..."
    _gnx_analyze_with_managed_node
  fi
  
  # Verificar API key
  local api_key=""
  if [ -n "$OPENAI_API_KEY" ]; then
    api_key="$OPENAI_API_KEY"
  elif [ -n "$GITNEXUS_API_KEY" ]; then
    api_key="$GITNEXUS_API_KEY"
  fi
  
  if [ -z "$api_key" ]; then
    echo "⚠️  No se encontró API key de OpenAI"
    echo "   Configura OPENAI_API_KEY o GITNEXUS_API_KEY"
    echo "   O ejecuta: gitnexus wiki --api-key <tu-api-key>"
    echo ""
    echo "📖 Alternativa: usa 'gnx-serve' para acceder a la wiki desde el UI"
    echo "   - gnx-serve"
    echo "   - Abre http://localhost:3100"
    return 1
  fi
  
  local wiki_output="$repo_root/docs/wiki"
  
  if [ ! -d "$wiki_output" ]; then
    echo "📁 Creando directorio $wiki_output..."
    mkdir -p "$wiki_output"
  fi
  
  echo "📚 Generando wiki en $wiki_output..."
  echo "   (Esto usa el LLM para generar documentación)"
  echo ""
  
  # Ejecutar gitnexus wiki - el argumento es el directorio de salida
  # gitnexus detectará automáticamente el repo desde el directorio actual
  if gitnexus wiki "$wiki_output" --api-key "$api_key" 2>&1; then
    echo ""
    echo "✅ Wiki generada en $wiki_output"
  else
    echo "❌ Error al generar wiki"
    return 1
  fi
}

# Función para analizar y servir en un solo comando
gnx-map() {
  if [ ! -d ".git" ]; then
    echo "❌ No estás en un repositorio Git"
    return 1
  fi
  
  echo "🗺️  Analizando y preparando servidor..."
  gnx-analyze-here
  echo ""
  echo "🚀 Iniciando servidor GitNexus..."
  echo "   Presiona Ctrl+C para detener"
  echo ""
  gnx-serve
}

