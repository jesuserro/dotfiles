alias ll="ls -alF"      # Lista detallada con / para directorios
alias la="ls -A"        # Lista casi todos los archivos, excluyendo . y ..
alias l="ls -CF"        # Lista compacta
alias ln="ln -v"        # Crear enlaces simbólicos verboso
