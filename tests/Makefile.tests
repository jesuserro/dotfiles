# Makefile.tests - Testing targets for dotfiles
# Include from root Makefile: include tests/Makefile.tests

TESTS_DIR := $(shell dirname $(abspath $(lastword $(MAKEFILE_LIST))))
DOTFILES_DIR := $(TESTS_DIR)/..

BATS_DIR := $(TESTS_DIR)/bats
BATS_HELPERS := $(BATS_DIR)/helpers/common.bash

# Zsh scripts are valid repo-owned scripts, but ShellCheck does not support the
# dialect; validate them with zsh -n instead.
ZSH_SCRIPTS := $(DOTFILES_DIR)/termux/install_plugins.sh
SHELLCHECK_EXCLUDED_SCRIPTS := $(ZSH_SCRIPTS)

# Shell scripts to lint (dotfiles-owned only, excludes third-party/vendor).
# Chezmoi templates are deliberately excluded: shellcheck/shfmt do not
# understand Go template delimiters reliably unless templates are rendered.
SHELL_SCRIPTS_ALL := $(shell find $(DOTFILES_DIR) -name '*.sh' -type f | grep -v '/\.git/' | grep -v '/\.venv/' | grep -v '/node_modules/' | grep -v '/vendor/' | grep -v '/__pycache__/')
SHELL_SCRIPTS := $(filter-out $(SHELLCHECK_EXCLUDED_SCRIPTS),$(SHELL_SCRIPTS_ALL))
SHELL_LAUNCHERS := $(shell find $(DOTFILES_DIR)/bin -type f \( -name 'mcp-*-launcher' -o -name 'tmux-dotfiles' -o -name 'playwright-docker' \) 2>/dev/null || true)
GIT_HOOKS := $(shell find $(DOTFILES_DIR)/.githooks -type f 2>/dev/null || true)
PROMPT_LAUNCHERS := $(shell find $(DOTFILES_DIR)/local/bin -name 'prompt-*' -type f 2>/dev/null || true)
AI_PROMPT_CLI := $(wildcard $(DOTFILES_DIR)/local/bin/ai-prompt)
SHELL_TESTS := $(shell find $(TESTS_DIR) -name '*.bats' -type f | grep -v '/\.git/')
YAML_FILES := $(shell find $(DOTFILES_DIR) \( -name '*.yaml' -o -name '*.yml' \) -type f | grep -v '/\.git/' | grep -v '/\.venv/' | grep -v '/node_modules/' | grep -v '/vendor/' | grep -v '/__pycache__/' | grep -v '/secrets\.sops\.yaml$$')
GITHUB_WORKFLOWS := $(shell find $(DOTFILES_DIR)/.github/workflows \( -name '*.yaml' -o -name '*.yml' \) -type f 2>/dev/null || true)
OSV_INPUTS := $(shell find $(DOTFILES_DIR) \( -name 'package-lock.json' -o -name 'pnpm-lock.yaml' -o -name 'yarn.lock' -o -name 'requirements*.txt' -o -name 'pyproject.toml' -o -name 'uv.lock' -o -name 'go.mod' -o -name 'Cargo.lock' -o -name 'composer.lock' \) -type f | grep -v '/\.git/' | grep -v '/\.venv/' | grep -v '/node_modules/' | grep -v '/vendor/' | grep -v '/__pycache__/')

# All shell files to lint
SHELL_FILES := $(SHELL_SCRIPTS) $(SHELL_LAUNCHERS) $(GIT_HOOKS) $(PROMPT_LAUNCHERS) $(AI_PROMPT_CLI) $(SHELL_TESTS)

# bats tests
BATS_DIR := $(TESTS_DIR)/bats
BATS_TESTS_MCP := $(wildcard $(BATS_DIR)/mcp/*.bats)
BATS_TESTS_CHEZMOI := $(wildcard $(BATS_DIR)/chezmoi/*.bats)
BATS_TESTS_COMMANDS := $(wildcard $(BATS_DIR)/commands/*.bats)
BATS_TESTS_PROMPTS := $(wildcard $(BATS_DIR)/prompts/*.bats)
BATS_TESTS_SYSTEM := $(wildcard $(BATS_DIR)/system/*.bats)
BATS_TESTS_TMUX := $(wildcard $(BATS_DIR)/tmux/*.bats)

# Color codes
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[1;33m
BLUE := \033[0;34m
NC := \033[0m

.PHONY: test test-fast test-lint test-bats test-bats-fast test-chezmoi test-install fmt-shell help bats-git-ai bats-git-flow bats-prompts bats-skills bats-tmux bats-gitnexus bats-git-hooks
.PHONY: test-ci test-bats-ci bats-docs test-commands generate-commands validate-commands materialize-commands validate-skills-structure
.PHONY: deps-check deps-install deps-actions bats-system bats-agent bats-zsh bats-gitnexus test-deps-check
.PHONY: quality-check security-check agent-validate agent-validate-audit agent-validate-full agent-validate-changed agent-validate-report ai-doctor lint-shellcheck lint-zsh lint-shfmt lint-yaml lint-actions security-gitleaks security-osv

