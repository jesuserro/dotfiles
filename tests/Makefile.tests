	@echo "Dotfiles — make targets"
	@echo ""
	@echo "Daily cheatsheet: docs/OPERATIONS_CHEATSHEET.md"
	@echo "More detail: docs/UPDATE.md, docs/TESTING.md, docs/INSTALL.md"
	@echo ""
	@echo "== Safe for agents / read-only =="
	@echo "  make chezmoi-drift-report        Chezmoi drift report; never applies"
	@echo "  make mcp-launcher-contract-check MCP launcher contract; HOME drift is warning"
	@echo "  make gitnexus-status             GitNexus index/lock/Node status; read-only"
	@echo "  make validate-skills-structure   Validate canonical skills tree"
	@echo "  make ai-mcp-governance           Validate/render/check MCP governance"
	@echo "  make ai-mcp-validate             Validate MANIFEST.yaml (PyYAML required)"
	@echo "  make ai-mcp-render               Dry-run MCP configs to build/mcps/"
	@echo "  make ai-mcp-drift                Drift report vs MCP templates"
	@echo "  make ai-cursor-check             Check Cursor/MCP readiness in HOME"
	@echo "  make update-check                Read-only update/runtime diagnostics"
	@echo "  make ai-doctor                   Read-only AI readiness checks"
	@echo "  make agent-validate              Dotfiles agent gate (read-only; skills, MCP, docs, changed files)"
	@echo "  make agent-validate-changed      Validate changed files only (local; SECURITY_ONLINE=1 for OSV)"
	@echo "  make agent-validate-audit        Full-repo quality + security audit (strict)"
	@echo "  make agent-validate-full         agent-validate + agent-validate-audit"
	@echo "  make agent-validate-report       Run agent-validate and write build/agent-validation/latest.md"
	@echo "  make bats-agent                  Agent-first regression index (meta-tests)"
	@echo "  make deps-check                  Check declarative system dependencies"
	@echo "  make deps-actions                Show actions for missing dependencies"
	@echo "  make test-chezmoi                Chezmoi smoke tests"
	@echo "  make test-bats-ci                CI bats subset (pre-PR parity)"
	@echo ""
	@echo "== Human / mutating / network =="
	@echo "  make update                      HUMAN: updates WSL/Windows tools; uses network"
	@echo "  make install                     HUMAN: bootstrap/install flow; see docs/INSTALL.md"
	@echo "  make deps-install                HUMAN: install APT dependencies (sudo)"
	@echo "  make install-agent-tools         HUMAN: install non-APT validation CLIs"
	@echo "  make install-mattpocock-skills   HUMAN unless DRY_RUN=1; external skills catalog"
	@echo "  make install-git-hooks           HUMAN: configure local core.hooksPath=.githooks"
	@echo "  make update-ai-skills            HUMAN: opt-in external skills catalog; use DRY_RUN=1 for preview"
	@echo "  make ai-mcp-generate APPLY=1     HUMAN: rewrites MCP templates in repo"
	@echo "  chezmoi apply                    HUMAN: not normal daily flow; see docs/CHEZMOI.md"
	@echo ""
	@echo "== Tests and quality =="
	@echo "  make test                        Full suite: preflight + lint + bats + templates"
	@echo "  make test-fast                   Lint + bats without chezmoi/* tests"
	@echo "  make test-ci                     GitHub Actions CI subset"
	@echo "  make test-lint                   shellcheck, zsh -n, shfmt, yamllint"
	@echo "  make test-bats                   All bats tests (preflight included)"
	@echo "  make test-commands               Commands tests only"
	@echo "  make test-deps-check             Fail-fast check for bats/shellcheck/shfmt/zsh"
	@echo "  make quality-check               Strict quality audit (shellcheck, shfmt, yamllint, actionlint)"
	@echo "  make security-check              gitleaks + osv-scanner"
	@echo "  make agent-validate              Dotfiles operational gate (see scripts/agent-validate-dotfiles.sh)"
	@echo "  make agent-validate-audit        quality-check + security-check"
	@echo "  make agent-validate-full         agent-validate + agent-validate-audit"
	@echo "  make fmt-shell                   Format shell scripts with shfmt"
	@echo "  make test-install                Install test dependencies (may use network)"
	@echo "  make generate-commands           Generate command artifacts"
	@echo "  make validate-commands           Validate command structure"
	@echo "  make materialize-commands        Materialize commands into runtime paths"
	@echo ""

# ============================================
# Installation
# ============================================

test-install:
	@echo "$(BLUE)==>$(NC) Installing test dependencies..."
	@command -v apt-get &>/dev/null && { \
		sudo apt-get update -qq && sudo apt-get install -y -qq shellcheck zsh 2>/dev/null || true; \
	} || true
	@command -v apt-get &>/dev/null && { \
		sudo apt-get install -y -qq shfmt 2>/dev/null || true; \
	} || true
	@if ! command -v shfmt &>/dev/null; then \
		if command -v go &>/dev/null; then \
			echo "$(BLUE)==>$(NC) Installing shfmt via Go..."; \
			go install mvdan.cc/sh/v3/cmd/shfmt@latest; \
		else \
			echo "$(YELLOW)==>$(NC) shfmt not found. Install via:"; \
			echo "  - apt: sudo apt install shfmt"; \
			echo "  - go:  go install mvdan.cc/sh/v3/cmd/shfmt@latest"; \
		fi \
	fi
	@if [ ! -d "/usr/share/bats" ] && [ ! -d "$$HOME/.local/share/bats" ]; then \
		echo "$(BLUE)==>$(NC) Installing bats-core..."; \
		git clone -q https://github.com/bats-core/bats-core.git /tmp/bats-core 2>/dev/null || true; \
		cd /tmp/bats-core && ./install.sh $$HOME/.local 2>/dev/null || true; \
		rm -rf /tmp/bats-core; \
	fi
	@echo "$(GREEN)==>$(NC) Test dependencies ready"

# ============================================
# Preflight: fail-fast for required test/lint deps
# ============================================
# Verifies that bats / shellcheck / shfmt / zsh are in PATH before invoking the
# corresponding suites. Avoids silent hangs and prints the actionable next
# command. These tools are declared as required APT packages in
# system/packages/ubuntu.yaml, so a single 'make install SKIP_EXTERNAL=1' fixes
# the missing ones on a fresh Ubuntu/WSL machine.

test-deps-check:
	@missing=""; \
	for cmd in bats shellcheck shfmt zsh; do \
		if ! command -v $$cmd >/dev/null 2>&1; then \
			if [ -z "$$missing" ]; then missing="$$cmd"; else missing="$$missing $$cmd"; fi; \
		fi; \
	done; \
	if [ -n "$$missing" ]; then \
		echo "Missing test dependency: $$missing"; \
		echo "These are declared as required APT packages in system/packages/ubuntu.yaml."; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or, for just the test/lint tooling: sudo apt-get install -y bats shellcheck shfmt zsh"; \
		exit 1; \
	fi; \
	echo "==> Test/lint dependencies present (bats, shellcheck, shfmt, zsh)"

# ============================================
# Linting
# ============================================

test-lint: lint-shellcheck lint-zsh lint-shfmt lint-yaml
	@echo ""
	@echo "$(GREEN)==>$(NC) Lint completed"

quality-check: lint-shellcheck lint-zsh lint-shfmt lint-yaml lint-actions
	@echo ""
	@echo "$(GREEN)==>$(NC) Quality checks completed"

security-check: security-gitleaks security-osv
	@echo ""
	@echo "$(GREEN)==>$(NC) Security checks completed (osv-scanner best-effort unless SECURITY_ONLINE=1)"

agent-validate-audit: quality-check security-check
	@echo ""
	@echo "$(GREEN)==>$(NC) Agent validation audit completed"

agent-validate:
	@SECURITY_ONLINE="$(SECURITY_ONLINE)" AGENT_VALIDATE_VERBOSE="$(AGENT_VALIDATE_VERBOSE)" \
		bash $(DOTFILES_DIR)/scripts/agent-validate-dotfiles.sh

agent-validate-full: agent-validate agent-validate-audit
	@echo ""
	@echo "$(GREEN)==>$(NC) Full agent validation completed"

agent-validate-report:
	@AGENT_VALIDATE_CMD="$(AGENT_VALIDATE_CMD)" \
		AGENT_VALIDATE_REPORT_PATH="$(AGENT_VALIDATE_REPORT_PATH)" \
		AGENT_VALIDATE_REPORT_DIR="$(AGENT_VALIDATE_REPORT_DIR)" \
		bash $(DOTFILES_DIR)/scripts/agent-validate-report.sh

agent-validate-changed:
	@SECURITY_ONLINE="$(SECURITY_ONLINE)" bash $(DOTFILES_DIR)/scripts/agent-validate-changed.sh

ai-doctor:
	@echo "$(BLUE)==>$(NC) AI doctor: dependency inventory"
	@$(MAKE) --no-print-directory deps-check DEPS_CHECK_ARGS=--include-optional
	@echo ""
	@echo "$(BLUE)==>$(NC) AI doctor: update readiness"
	@$(MAKE) --no-print-directory update-check
	@echo ""
	@echo "$(BLUE)==>$(NC) AI doctor: Cursor/AI/MCP readiness"
	@$(MAKE) --no-print-directory ai-cursor-check
	@echo ""
	@echo "$(BLUE)==>$(NC) AI doctor: MCP governance"
	@$(MAKE) --no-print-directory ai-mcp-governance
	@echo ""
	@echo "$(BLUE)==>$(NC) AI doctor: skills structure"
	@bash $(DOTFILES_DIR)/scripts/validate-skills-structure.sh
	@echo ""
	@echo "$(BLUE)==>$(NC) AI doctor: commands structure"
	@bash $(DOTFILES_DIR)/scripts/validate-commands-structure.sh
	@echo ""
	@echo "$(BLUE)==>$(NC) AI doctor: secret scan"
	@$(MAKE) --no-print-directory security-gitleaks
	@echo ""
	@echo "$(GREEN)==>$(NC) AI doctor completed"

lint-shellcheck:
	@echo "$(BLUE)==>$(NC) Running shellcheck..."
	@if ! command -v shellcheck >/dev/null 2>&1; then \
		echo "Missing test dependency: shellcheck"; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or:  sudo apt-get install -y shellcheck"; \
		exit 1; \
	fi
	@shellcheck_warnings=0; \
	for f in $(SHELL_FILES); do \
		if shellcheck -x -S warning "$$f" 2>/dev/null; then \
			echo "$(GREEN)  OK$(NC) $$f"; \
		else \
			echo "$(YELLOW)  WARN$(NC) $$f"; \
			shellcheck_warnings=$$((shellcheck_warnings + 1)); \
		fi; \
	done; \
	if [ $$shellcheck_warnings -gt 0 ]; then \
		echo "$(YELLOW)==>$(NC) shellcheck: $$shellcheck_warnings file(s) with warnings"; \
	else \
		echo "$(GREEN)==>$(NC) shellcheck passed"; \
	fi

lint-zsh:
	@echo "$(BLUE)==>$(NC) Running zsh syntax check..."
	@if ! command -v zsh >/dev/null 2>&1; then \
		echo "Missing test dependency: zsh"; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or:  sudo apt-get install -y zsh"; \
		exit 1; \
	fi
	@for f in $(ZSH_SCRIPTS); do \
		zsh -n "$$f"; \
		echo "$(GREEN)  OK$(NC) $$f"; \
	done

lint-shfmt:
	@echo "$(BLUE)==>$(NC) Running shfmt check..."
	@if ! command -v shfmt >/dev/null 2>&1; then \
		echo "Missing test dependency: shfmt"; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or:  sudo apt-get install -y shfmt"; \
		exit 1; \
	fi
	@unformatted=0; \
	for f in $(SHELL_FILES); do \
		diff="$$(shfmt -l "$$f" 2>/dev/null || true)"; \
		if [ -n "$$diff" ]; then \
			echo "$(YELLOW)  DIFF$(NC) $$f"; \
			unformatted=$$((unformatted + 1)); \
		fi; \
	done; \
	if [ $$unformatted -gt 0 ]; then \
		echo "$(YELLOW)==>$(NC) shfmt: $$unformatted file(s) differ. Run: make fmt-shell"; \
	else \
		echo "$(GREEN)==>$(NC) shfmt passed"; \
	fi

lint-yaml:
	@echo "$(BLUE)==>$(NC) Running yamllint..."
	@if ! command -v yamllint >/dev/null 2>&1; then \
		echo "Missing validation dependency: yamllint"; \
		echo "Run: make deps-install"; \
		echo "Or:  sudo apt-get install -y yamllint"; \
		exit 1; \
	fi
	@if [ -z "$(YAML_FILES)" ]; then \
		echo "$(YELLOW)==>$(NC) yamllint skipped: no YAML files found"; \
	else \
		yamllint -s $(YAML_FILES); \
		echo "$(GREEN)==>$(NC) yamllint passed"; \
	fi

lint-actions:
	@echo "$(BLUE)==>$(NC) Running actionlint..."
	@if [ -z "$(GITHUB_WORKFLOWS)" ]; then \
		echo "$(YELLOW)==>$(NC) actionlint skipped: no GitHub Actions workflows found"; \
	elif ! command -v actionlint >/dev/null 2>&1; then \
		echo "Missing validation dependency: actionlint"; \
		echo "Run: make install-agent-tools"; \
		exit 1; \
	else \
		actionlint -shellcheck= $(GITHUB_WORKFLOWS); \
		echo "$(GREEN)==>$(NC) actionlint passed"; \
	fi

security-gitleaks:
	@echo "$(BLUE)==>$(NC) Running gitleaks working-tree scan..."
	@if ! command -v gitleaks >/dev/null 2>&1; then \
		echo "Missing security dependency: gitleaks"; \
		echo "Run: make deps-install"; \
		echo "Or:  sudo apt-get install -y gitleaks"; \
		exit 1; \
	fi
	@gitleaks detect --source "$(DOTFILES_DIR)" --no-git --redact --no-banner
	@echo "$(GREEN)==>$(NC) gitleaks passed"

security-osv:
	@bash $(DOTFILES_DIR)/scripts/security-osv-scan.sh

fmt-shell:
	@echo "$(BLUE)==>$(NC) Formatting shell scripts with shfmt..."
	@if ! command -v shfmt &>/dev/null; then \
		echo "$(RED)==>$(NC) shfmt not installed. Run: make test-install"; \
		exit 1; \
	fi
	@formatted=0; \
	for f in $(SHELL_FILES); do \
		if ! shfmt -l "$$f" >/dev/null 2>&1; then \
			shfmt -w "$$f"; \
			echo "$(BLUE)  fmt$(NC) $$f"; \
			formatted=$$((formatted + 1)); \
		fi; \
	done; \
	if [ $$formatted -gt 0 ]; then \
		echo "$(GREEN)==>$(NC) Formatted $$formatted file(s)"; \
	else \
		echo "$(GREEN)==>$(NC) All files already formatted"; \
	fi

# ============================================
# Bats tests (human-readable output)
# ============================================

test-bats: test-deps-check bats-helpers bats-mcp bats-chezmoi bats-skills bats-commands bats-git-ai bats-git-flow bats-git-hooks bats-prompts bats-system
