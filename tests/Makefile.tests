# Makefile.tests - Testing targets for dotfiles
# Include from root Makefile: include tests/Makefile.tests

TESTS_DIR := $(shell dirname $(abspath $(lastword $(MAKEFILE_LIST))))
DOTFILES_DIR := $(TESTS_DIR)/..

BATS_DIR := $(TESTS_DIR)/bats
BATS_HELPERS := $(BATS_DIR)/helpers/common.bash

# Shell scripts to lint (dotfiles-owned only, excludes third-party/vendor)
SHELL_SCRIPTS := $(shell find $(DOTFILES_DIR) -name '*.sh' -type f | grep -v '/\.git/' | grep -v '/\.venv/' | grep -v '/node_modules/' | grep -v '/vendor/' | grep -v '/__pycache__/')
SHELL_LAUNCHERS := $(shell find $(DOTFILES_DIR)/bin -name 'mcp-*-launcher' -type f 2>/dev/null || true)
PROMPT_LAUNCHERS := $(shell find $(DOTFILES_DIR)/local/bin -name 'prompt-*' -type f 2>/dev/null || true)
SHELL_CHEZMOI := $(shell find $(DOTFILES_DIR)/.chezmoiscripts -name '*.tmpl' -type f 2>/dev/null || true)
SHELL_TESTS := $(shell find $(TESTS_DIR) -name '*.bats' -type f | grep -v '/\.git/')

# All shell files to lint
SHELL_FILES := $(SHELL_SCRIPTS) $(SHELL_LAUNCHERS) $(PROMPT_LAUNCHERS) $(SHELL_CHEZMOI) $(SHELL_TESTS)

# bats tests
BATS_DIR := $(TESTS_DIR)/bats
BATS_TESTS_MCP := $(wildcard $(BATS_DIR)/mcp/*.bats)
BATS_TESTS_CHEZMOI := $(wildcard $(BATS_DIR)/chezmoi/*.bats)
BATS_TESTS_COMMANDS := $(wildcard $(BATS_DIR)/commands/*.bats)
BATS_TESTS_PROMPTS := $(wildcard $(BATS_DIR)/prompts/*.bats)
BATS_TESTS_SYSTEM := $(wildcard $(BATS_DIR)/system/*.bats)

# Color codes
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[1;33m
BLUE := \033[0;34m
NC := \033[0m

.PHONY: test test-fast test-lint test-bats test-chezmoi test-install fmt-shell help bats-git-ai bats-prompts
.PHONY: test-ci test-bats-ci test-commands generate-commands validate-commands materialize-commands
.PHONY: deps-check deps-install deps-actions bats-system bats-zsh test-deps-check

help:
	@echo "Testing targets for dotfiles"
	@echo ""
	@echo "  make test         - Run all tests (preflight + lint + bats + chezmoi)"
	@echo "  make test-fast    - Run preflight + lint + bats (no chezmoi smoke)"
	@echo "  make test-deps-check - Fail-fast check for bats/shellcheck/shfmt in PATH"
	@echo "  make test-lint    - Run shellcheck and shfmt checks (fail if tool missing)"
	@echo "  make test-bats    - Run bats tests only (preflight included)"
	@echo "  make test-chezmoi - Run chezmoi smoke tests only"
	@echo "  make test-commands- Run commands tests only"
	@echo "  make test-install - Install test dependencies"
	@echo "  make fmt-shell    - Format shell scripts with shfmt"
	@echo "  make deps-check   - Check declarative system dependencies"
	@echo "  make deps-install - Install declarative system dependencies on Ubuntu/Debian"
	@echo "  make deps-actions - Show recommended actions for missing dependencies"
	@echo "  make ai-cursor-check - Cursor/MCP/skills readiness (repo root; target in install.mk; covered by bats-system)"
	@echo "  make ai-mcp-validate - Validate ai/assets/mcps/MANIFEST.yaml (PyYAML required)"
	@echo "  make ai-mcp-render   - Dry-run MCP configs to build/mcps/ (PyYAML required)"
	@echo "  make ai-mcp-drift    - Drift report vs templates (PyYAML required)"
	@echo "  make ai-mcp-governance - validate + render + drift (non-mutating; PyYAML required)"
	@echo "  make ai-mcp-generate - Plan only; use APPLY=1 to write productive MCP templates (PyYAML required)"
	@echo ""
	@echo "  make generate-commands  - Generate command artifacts"
	@echo "  make validate-commands  - Validate command structure"
	@echo "  make materialize-commands - Materialize commands into runtime paths"
	@echo ""
	@echo "  make test-ci      - Run all tests with CI output (JUnit/XML)"
	@echo ""

# ============================================
# Installation
# ============================================

test-install:
	@echo "$(BLUE)==>$NC Installing test dependencies..."
	@command -v apt-get &>/dev/null && { \
		sudo apt-get update -qq && sudo apt-get install -y -qq shellcheck 2>/dev/null || true; \
	} || true
	@command -v apt-get &>/dev/null && { \
		sudo apt-get install -y -qq shfmt 2>/dev/null || true; \
	} || true
	@if ! command -v shfmt &>/dev/null; then \
		if command -v go &>/dev/null; then \
			echo "$(BLUE)==>$NC Installing shfmt via Go..."; \
			go install mvdan.cc/sh/v3/cmd/shfmt@latest; \
		else \
			echo "$(YELLOW)==>$NC shfmt not found. Install via:"; \
			echo "  - apt: sudo apt install shfmt"; \
			echo "  - go:  go install mvdan.cc/sh/v3/cmd/shfmt@latest"; \
		fi \
	fi
	@if [ ! -d "/usr/share/bats" ] && [ ! -d "$$HOME/.local/share/bats" ]; then \
		echo "$(BLUE)==>$NC Installing bats-core..."; \
		git clone -q https://github.com/bats-core/bats-core.git /tmp/bats-core 2>/dev/null || true; \
		cd /tmp/bats-core && ./install.sh $$HOME/.local 2>/dev/null || true; \
		rm -rf /tmp/bats-core; \
	fi
	@echo "$(GREEN)==>$NC Test dependencies ready"

# ============================================
# Preflight: fail-fast for required test/lint deps
# ============================================
# Verifies that bats / shellcheck / shfmt are in PATH before invoking the
# corresponding suites. Avoids silent hangs and prints the actionable next
# command. All three are declared as required APT packages in
# system/packages/ubuntu.yaml, so a single 'make install SKIP_EXTERNAL=1' fixes
# the missing ones on a fresh Ubuntu/WSL machine.

test-deps-check:
	@missing=""; \
	for cmd in bats shellcheck shfmt; do \
		if ! command -v $$cmd >/dev/null 2>&1; then \
			if [ -z "$$missing" ]; then missing="$$cmd"; else missing="$$missing $$cmd"; fi; \
		fi; \
	done; \
	if [ -n "$$missing" ]; then \
		echo "Missing test dependency: $$missing"; \
		echo "These are declared as required APT packages in system/packages/ubuntu.yaml."; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or, for just the test/lint tooling: sudo apt-get install -y bats shellcheck shfmt"; \
		exit 1; \
	fi; \
	echo "==> Test/lint dependencies present (bats, shellcheck, shfmt)"

# ============================================
# Linting
# ============================================

test-lint: lint-shellcheck lint-shfmt
	@echo ""
	@echo "$(GREEN)==>$NC Lint completed"

lint-shellcheck:
	@echo "$(BLUE)==>$(NC) Running shellcheck..."
	@if ! command -v shellcheck >/dev/null 2>&1; then \
		echo "Missing test dependency: shellcheck"; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or:  sudo apt-get install -y shellcheck"; \
		exit 1; \
	fi
	@shellcheck_warnings=0; \
	for f in $(SHELL_FILES); do \
		if shellcheck -x -S warning "$$f" 2>/dev/null; then \
			echo "$(GREEN)  OK$(NC) $$f"; \
		else \
			echo "$(YELLOW)  WARN$(NC) $$f"; \
			shellcheck_warnings=$$((shellcheck_warnings + 1)); \
		fi; \
	done; \
	if [ $$shellcheck_warnings -gt 0 ]; then \
		echo "$(YELLOW)==>$NC shellcheck: $$shellcheck_warnings file(s) with warnings"; \
	else \
		echo "$(GREEN)==>$NC shellcheck passed"; \
	fi

lint-shfmt:
	@echo "$(BLUE)==>$(NC) Running shfmt check..."
	@if ! command -v shfmt >/dev/null 2>&1; then \
		echo "Missing test dependency: shfmt"; \
		echo "Run: make install SKIP_EXTERNAL=1"; \
		echo "Or:  sudo apt-get install -y shfmt"; \
		exit 1; \
	fi
	@unformatted=0; \
	for f in $(SHELL_FILES); do \
		if ! shfmt -l "$$f" >/dev/null 2>&1; then \
			echo "$(YELLOW)  DIFF$(NC) $$f"; \
			unformatted=$$((unformatted + 1)); \
		fi; \
	done; \
	if [ $$unformatted -gt 0 ]; then \
		echo "$(YELLOW)==>$NC shfmt: $$unformatted file(s) differ. Run: make fmt-shell"; \
	else \
		echo "$(GREEN)==>$NC shfmt passed"; \
	fi

fmt-shell:
	@echo "$(BLUE)==>$NC Formatting shell scripts with shfmt..."
	@if ! command -v shfmt &>/dev/null; then \
		echo "$(RED)==>$NC shfmt not installed. Run: make test-install"; \
		exit 1; \
	fi
	@formatted=0; \
	for f in $(SHELL_FILES); do \
		if ! shfmt -l "$$f" >/dev/null 2>&1; then \
			shfmt -w "$$f"; \
			echo "$(BLUE)  fmt$(NC) $$f"; \
			formatted=$$((formatted + 1)); \
		fi; \
	done; \
	if [ $$formatted -gt 0 ]; then \
		echo "$(GREEN)==>$NC Formatted $$formatted file(s)"; \
	else \
		echo "$(GREEN)==>$NC All files already formatted"; \
	fi

# ============================================
# Bats tests (human-readable output)
# ============================================

test-bats: test-deps-check bats-helpers bats-mcp bats-chezmoi bats-commands bats-git-ai bats-prompts bats-system
	@echo ""
	@echo "$(GREEN)==>$NC Bats tests passed"

bats-helpers:
	@echo "$(BLUE)==>$NC Checking bats helpers..."
	@if [ ! -f "$(BATS_HELPERS)" ]; then \
		echo "$(RED)==>$NC Helpers not found at $(BATS_HELPERS)"; \
		exit 1; \
	fi
	@echo "$(GREEN)==>$NC Helpers OK"

bats-mcp: bats-filesystem bats-chezmoi-mcp-launchers bats-git bats-governance
	@echo "$(GREEN)==>$NC MCP tests passed"

bats-filesystem:
	@echo "$(BLUE)==>$NC Running filesystem-launcher tests..."
	@$(call run_bats,$(BATS_DIR)/mcp/filesystem-launcher.bats)

bats-chezmoi-mcp-launchers:
	@echo "$(BLUE)==>$NC Running chezmoi MCP launcher template tests..."
	@$(call run_bats,$(BATS_DIR)/mcp/chezmoi-mcp-launcher-templates.bats)

bats-git:
	@echo "$(BLUE)==>$NC Running git-launcher tests..."
	@$(call run_bats,$(BATS_DIR)/mcp/git-launcher.bats)

bats-governance:
	@echo "$(BLUE)==>$NC Running validate-governance tests..."
	@$(call run_bats,$(BATS_DIR)/mcp/validate-governance.bats)

bats-chezmoi:
	@echo "$(BLUE)==>$NC Running chezmoi smoke tests..."
	@$(call run_bats,$(BATS_DIR)/chezmoi/smoke.bats)

bats-commands:
	@echo "$(BLUE)==>$NC Running commands tests..."
	@$(call run_bats,$(BATS_DIR)/commands/validate-commands.bats)

bats-git-ai:
	@echo "$(BLUE)==>$NC Running git-ai-author tests..."
	@$(call run_bats,$(BATS_DIR)/git-ai-author.bats)

bats-prompts:
	@echo "$(BLUE)==>$NC Running prompt launcher tests..."
	@$(call run_bats,$(BATS_DIR)/prompts/prompt-launchers.bats)

bats-system: bats-zsh
	@echo "$(BLUE)==>$NC Running system dependency tests..."
	@$(call run_bats,$(BATS_DIR)/system/system-deps.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-dotfiles.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-uv.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-sops.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-chezmoi.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-node-stack.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-mcp-github.bats)
	@$(call run_bats,$(BATS_DIR)/system/install-mcp-excalidraw.bats)
	@$(call run_bats,$(BATS_DIR)/system/dry-run-guard.bats)
	@$(call run_bats,$(BATS_DIR)/system/azure-tools.bats)
	@$(call run_bats,$(BATS_DIR)/system/ai-cursor-check.bats)
	@$(call run_bats,$(BATS_DIR)/system/mcp-manifest.bats)
	@$(call run_bats,$(BATS_DIR)/system/mcp-render-drift.bats)

bats-zsh:
	@echo "$(BLUE)==>$NC Running zsh stack RC symlink tests..."
	@$(call run_bats,$(BATS_DIR)/zsh/rc_symlinks.bats)
	@echo "$(BLUE)==>$NC Running ups MCP glob regression tests..."
	@$(call run_bats,$(BATS_DIR)/zsh/ups_mcp_glob.bats)

# ============================================
# CI targets (JUnit/XML output)
# ============================================

test-ci: test-lint test-bats-ci test-chezmoi
	@echo ""
	@echo "$(GREEN)==>$NC CI tests completed"

test-bats-ci: bats-helpers bats-filesystem bats-chezmoi-mcp-launchers bats-git bats-governance bats-chezmoi

# ============================================
# Combined tests
# ============================================

test: test-deps-check test-lint test-bats
	@echo ""
	@echo "$(GREEN)========================================"
	@echo "All tests passed"
	@echo "========================================$(NC)"

deps-check:
	@bash $(DOTFILES_DIR)/scripts/check-system-deps.sh $(DEPS_CHECK_ARGS)

deps-install:
	@bash $(DOTFILES_DIR)/scripts/install-system-packages.sh $(DEPS_INSTALL_ARGS)

deps-actions:
	@bash $(DOTFILES_DIR)/scripts/show-system-deps-actions.sh $(DEPS_ACTION_ARGS)

test-fast: test-deps-check test-lint test-bats
	@echo ""
	@echo "$(GREEN)========================================"
	@echo "Fast tests passed"
	@echo "========================================$(NC)"

test-chezmoi: chezmoi-templates bats-chezmoi
	@echo "$(GREEN)==>$NC Chezmoi smoke tests passed"

chezmoi-templates:
	@echo "$(BLUE)==>$NC Validating MCP template syntax..."
	@$(call run_chezmoi_templates)

# ============================================
# Helper functions
# ============================================

define run_bats
	@if command -v bats &>/dev/null; then \
		bats $(1); \
	elif [ -x "$(HOME)/.local/bin/bats" ]; then \
		$$HOME/.local/bin/bats $(1); \
	else \
		echo "$(RED)==>$NC bats not installed. Run: make test-install"; \
		exit 1; \
	fi
endef

define run_bats_ci
	@if command -v bats &>/dev/null; then \
		bats --timing --formatter junit $(1) 2>&1 || { \
			echo "$(RED)==>$NC Test failed"; \
			exit 1; \
		}; \
	elif [ -x "$(HOME)/.local/bin/bats" ]; then \
		$$HOME/.local/bin/bats --timing --formatter junit $(1) 2>&1 || { \
			echo "$(RED)==>$NC Test failed"; \
			exit 1; \
		}; \
	else \
		echo "$(RED)==>$NC bats not installed. Run: make test-install"; \
		exit 1; \
	fi
endef

define run_chezmoi_templates
	@echo "$(BLUE)  Checking JSON templates...$(NC)"; \
	if command -v python3 &>/dev/null; then \
		if python3 -c "import json" 2>/dev/null; then \
			for tmpl in $(DOTFILES_DIR)/dot_cursor/mcp.json.tmpl $(DOTFILES_DIR)/dot_config/opencode/opencode.json.tmpl; do \
				if [ -f "$$tmpl" ]; then \
					echo "$(BLUE)    Check$(NC) $$(basename "$$tmpl")"; \
				fi \
			done \
			&& echo "$(GREEN)  Templates OK$(NC)"; \
		else \
			echo "$(YELLOW)  Python json module not available$(NC)"; \
		fi \
	else \
		echo "$(YELLOW)  Python3 not available for template validation$(NC)"; \
	fi
endef

# ============================================
# Commands
# ============================================

generate-commands:
	@echo "$(BLUE)==>$NC Generating commands..."
	@if [ -x "$(DOTFILES_DIR)/scripts/generate-commands.sh" ]; then \
		$(DOTFILES_DIR)/scripts/generate-commands.sh; \
	else \
		echo "$(RED)==>$NC generate-commands.sh not found or not executable"; \
		exit 1; \
	fi

validate-commands:
	@echo "$(BLUE)==>$NC Validating commands structure..."
	@if [ -x "$(DOTFILES_DIR)/scripts/validate-commands-structure.sh" ]; then \
		$(DOTFILES_DIR)/scripts/validate-commands-structure.sh; \
	else \
		echo "$(RED)==>$NC validate-commands-structure.sh not found or not executable"; \
		exit 1; \
	fi

materialize-commands:
	@echo "$(BLUE)==>$NC Materializing commands..."
	@if [ -x "$(DOTFILES_DIR)/scripts/materialize-commands.sh" ]; then \
		$(DOTFILES_DIR)/scripts/materialize-commands.sh; \
	else \
		echo "$(RED)==>$NC materialize-commands.sh not found or not executable"; \
		exit 1; \
	fi

test-commands: bats-commands validate-commands
	@echo "$(GREEN)==>$NC Commands tests passed"
