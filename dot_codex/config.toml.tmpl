model = "gpt-5.4"
model_reasoning_effort = "medium"

# Codex internal logs (keep separate from your ETL logs/)
log_dir = "~/.codex-logs"

# ─────────────────────────────────────────────
# MCP: Excalidraw (diagramas)
# ─────────────────────────────────────────────

[mcp_servers.excalidraw_canvas]
command = "docker"
args = ["run", "-i", "--rm", "-e", "EXPRESS_SERVER_URL=http://host.docker.internal:3210", "-e", "ENABLE_CANVAS_SYNC=true", "ghcr.io/yctimlin/mcp_excalidraw:latest"]
enabled = true

[mcp_servers.context7]
command = "npx"
args = ["-y", "@upstash/context7-mcp"]
enabled = true

[mcp_servers.docker]
command = "docker.exe"
args = ["mcp", "gateway", "run"]
enabled = true

[mcp_servers.grafana]
command = "uvx"
args = ["mcp-grafana"]
enabled = true

[mcp_servers.grafana.env]
GRAFANA_PASSWORD = "admin"
GRAFANA_URL = "http://localhost:3002"
GRAFANA_USERNAME = "admin"

[mcp_servers.opentelemetry]
command = "uvx"
args = ["--with", "opentelemetry-semantic-conventions-ai==0.4.13", "opentelemetry-mcp"]
enabled = true

[mcp_servers.opentelemetry.env]
BACKEND_TYPE = "tempo"
BACKEND_URL = "http://localhost:3200"

[mcp_servers.github]
command = "/usr/bin/bash"
args = ["-lc", "source ~/.secrets/codex.env 2>/dev/null; exec {{ .chezmoi.homeDir }}/.local/bin/codex-mcp-github"]
enabled = true

[mcp_servers.fetch]
command = "uvx"
args = ["mcp-server-fetch"]
enabled = true

[mcp_servers.gitnexus]
command = "{{ .chezmoi.homeDir }}/.local/share/chezmoi/bin/mcp-gitnexus-launcher"
args = []
enabled = true

[mcp_servers.filesystem]
command = "{{ .chezmoi.homeDir }}/.local/share/chezmoi/bin/mcp-filesystem-launcher"
args = []
enabled = true

[mcp_servers.git]
command = "{{ .chezmoi.homeDir }}/.local/share/chezmoi/bin/mcp-git-launcher"
args = []
enabled = true

[mcp_servers.sequential-thinking]
command = "npx"
args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]
enabled = true

[mcp_servers.obsidian]
command = "npx"
args = ["-y", "@bitbonsai/mcpvault", "{{ .ai.obsidian_vault_path }}"]
enabled = true

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@executeautomation/playwright-mcp-server"]
enabled = true

[mcp_servers.postgres]
command = "{{ .chezmoi.homeDir }}/.local/share/chezmoi/bin/mcp-postgres-launcher"
args = []
enabled = true

[mcp_servers.postgres.env]
MCP_POSTGRES_SECRETS = "{{ .chezmoi.homeDir }}/.config/mcp-secrets.env"

[mcp_servers.trino]
command = "{{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python"
args = ["-m", "trino_mcp"]
enabled = true

[mcp_servers.trino.env]
AUTH_METHOD = "NONE"
TRINO_CATALOG = "iceberg"
TRINO_HOST = "localhost"
TRINO_HTTP_SCHEME = "http"
TRINO_PORT = "8080"
TRINO_USER = "admin"

[mcp_servers.dagster]
command = "{{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python"
args = ["{{ .chezmoi.homeDir }}/dotfiles/ai/runtime/mcp/servers/dagster/server.py"]
enabled = true

[mcp_servers.dagster.env]
DAGSTER_GRAPHQL_URL = "http://localhost:3000/graphql"
DAGSTER_TIMEOUT_SECONDS = "30"

[mcp_servers.minio]
command = "/usr/bin/bash"
args = ["-lc", "source ~/.secrets/codex.env 2>/dev/null; export MINIO_ENDPOINT='http://localhost:9000'; export MINIO_SECURE='false'; export MINIO_REGION='us-east-1'; exec {{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python {{ .chezmoi.homeDir }}/dotfiles/ai/runtime/mcp/servers/minio/server.py"]
enabled = true

[mcp_servers.tempo]
command = "{{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python"
args = ["{{ .chezmoi.homeDir }}/dotfiles/ai/runtime/mcp/servers/tempo/server.py"]
enabled = true

[mcp_servers.tempo.env]
TEMPO_BASE_URL = "http://localhost:3200"
TEMPO_TIMEOUT_SECONDS = "30"

[mcp_servers.loki]
command = "{{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python"
args = ["{{ .chezmoi.homeDir }}/dotfiles/ai/runtime/mcp/servers/loki/server.py"]
enabled = true

[mcp_servers.loki.env]
LOKI_BASE_URL = "http://localhost:3100"
LOKI_TIMEOUT_SECONDS = "30"

[mcp_servers.prometheus]
command = "{{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python"
args = ["{{ .chezmoi.homeDir }}/dotfiles/ai/runtime/mcp/servers/prometheus/server.py"]
enabled = true

[mcp_servers.prometheus.env]
PROMETHEUS_TIMEOUT_SECONDS = "15"
PROMETHEUS_URL = "http://localhost:9090"

[mcp_servers.store_etl_ops]
command = "{{ .chezmoi.homeDir }}/.config/ai/runtime/.venv/bin/python"
args = ["{{ .chezmoi.homeDir }}/dotfiles/ai/runtime/mcp/servers/store_etl_ops/server.py"]
enabled = true

[plugins."github@openai-curated"]
enabled = true
