#!/usr/bin/env bash
# MCP governance: repo coherence (manifest + recipes + templates).
#
# Canonical MCP *intent* lives in ai/assets/mcps/MANIFEST.yaml.
# This script orchestrates the same non-mutating checks as:
#   make ai-mcp-validate && make ai-mcp-render && make ai-mcp-drift
#
# It does NOT validate local readiness (HOME, secrets, binaries, Cursor runtime);
# use: make ai-cursor-check
#
# See: docs/adr/0001-mcp-governance.md, docs/MCP_QUICKREF.md

set -euo pipefail

_bin_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_default_root="$(cd "${_bin_dir}/.." && pwd)"
if [[ -n "${DOTFILES_DIR:-}" ]]; then
	if [[ ! -d "$DOTFILES_DIR" ]]; then
		echo "MCP governance validation: FAIL" >&2
		echo "DOTFILES_DIR is not a directory: $DOTFILES_DIR" >&2
		exit 1
	fi
	DOTFILES_DIR="$(cd "$DOTFILES_DIR" && pwd)"
else
	DOTFILES_DIR="$_default_root"
fi

if [[ ! -f "${DOTFILES_DIR}/Makefile" ]] || [[ ! -d "${DOTFILES_DIR}/ai/assets/mcps" ]]; then
	echo "MCP governance validation: FAIL" >&2
	echo "DOTFILES_DIR does not look like dotfiles repo root: $DOTFILES_DIR" >&2
	exit 1
fi

_run_make() {
	local target=$1
	echo ""
	echo "========================================"
	echo "==> make ${target}"
	echo "========================================"
	if ! make -C "$DOTFILES_DIR" "$target"; then
		local ec=$?
		echo "MCP governance validation: FAIL" >&2
		exit "$ec"
	fi
}

echo "MCP governance (validate + render + drift)"
echo "DOTFILES_DIR=${DOTFILES_DIR}"

_run_make ai-mcp-validate
_run_make ai-mcp-render
_run_make ai-mcp-drift

echo ""
echo "MCP governance validation: PASS"
exit 0
