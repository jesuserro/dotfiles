FLOW_MODE_TO_DEV=local
FLOW_MODE_TO_MAIN=pr

VALIDATE_TO_DEV=false
VALIDATE_TO_MAIN=true

VALIDATE_CMD_TO_DEV="make bats-git-flow && make bats-docs && make test-lint"
VALIDATE_CMD_TO_MAIN="make bats-git-flow && make bats-docs && make test-lint"

MERGE_STRATEGY_TO_DEV=merge
MERGE_STRATEGY_TO_MAIN=merge

DELETE_FEATURE_BRANCH=false
OPEN_BROWSER=false

REMOTE_NAME=origin
BASE_DEV_BRANCH=dev
BASE_MAIN_BRANCH=main
FEATURE_BRANCH_PREFIX=feature/