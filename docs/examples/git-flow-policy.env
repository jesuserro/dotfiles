# Example Git Flow policy for repositories managed with dotfiles.
# Copy this file to the root of a project as:
# .git-flow-policy.env
#
# Without this file, git feat / git rel keep legacy defaults.
#
# PR modes: pr (manual), pr_auto (auto-merge), pr_immediate (merge now).
# MERGE_STRATEGY_* applies to pr_auto and pr_immediate only.
# Requires authenticated GitHub CLI (`gh`) outside tests.
#
# Dotfiles repo profile (manual PR, agent validation) — see repo root
# .git-flow-policy.env for the live copy:
#
# FLOW_MODE_TO_DEV=pr
# FLOW_MODE_TO_MAIN=pr
# VALIDATE_CMD_TO_DEV="make agent-validate"
# VALIDATE_CMD_TO_MAIN="make agent-validate-full"

FLOW_MODE_TO_DEV=local
FLOW_MODE_TO_MAIN=local

VALIDATE_TO_DEV=true
VALIDATE_CMD_TO_DEV="make validate"

VALIDATE_TO_MAIN=true
VALIDATE_CMD_TO_MAIN="make validate-full"

MERGE_STRATEGY_TO_DEV=merge
MERGE_STRATEGY_TO_MAIN=merge

DELETE_FEATURE_BRANCH=false
OPEN_BROWSER=true

REMOTE_NAME=origin
BASE_DEV_BRANCH=dev
BASE_MAIN_BRANCH=main
FEATURE_BRANCH_PREFIX=feature/
