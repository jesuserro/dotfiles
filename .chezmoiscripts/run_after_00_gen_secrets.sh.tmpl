#!/usr/bin/env bash
# Genera ~/.config/store-etl/secrets.env desde secrets.sops.yaml (SOPS)
# Se ejecuta después de apply. Requiere: sops, yq O python3+PyYAML.
# Si sops no está o el archivo no está cifrado, sale con 0 (no fallar apply).
#
# Token GitHub: solo classic (ghp_) en SOPS. Fine-grained deprecado (sin Projects).
# GITHUB_TOKEN/GH_TOKEN se exportan para gh, MCPs, Cursor. Ver docs/TOKEN_GITHUB_GH.md.
SOURCE_DIR="{{ .chezmoi.sourceDir }}"
SECRETS_YAML="${SOURCE_DIR}/secrets.sops.yaml"
OUT="${HOME}/.config/store-etl/secrets.env"
TMP=
cleanup() { [[ -n "$TMP" ]] && rm -f "$TMP"; }
trap cleanup EXIT

[[ -f "$SECRETS_YAML" ]] || exit 0

# Symlink compatibilidad: ~/.secrets/codex.env -> ~/.config/store-etl/secrets.env
mkdir -p "${HOME}/.secrets"
ln -sf "${HOME}/.config/store-etl/secrets.env" "${HOME}/.secrets/codex.env" 2>/dev/null || true

command -v sops >/dev/null 2>&1 || exit 0

mkdir -p "$(dirname "$OUT")"
TMP=$(mktemp 2>/dev/null) || true
[[ -n "$TMP" && -f "$TMP" ]] || exit 0
sops -d "$SECRETS_YAML" > "$TMP" 2>/dev/null || exit 0
if command -v yq >/dev/null 2>&1; then
  gpat=$(yq -r '.mcp.github_personal_access_token // ""' "$TMP")
  pdsn=$(yq -r '.mcp.postgres_dsn // ""' "$TMP")
  mak=$(yq -r '.mcp.minio_access_key // ""' "$TMP")
  msk=$(yq -r '.mcp.minio_secret_key // ""' "$TMP")
  cat > "$OUT" << EOF
# Generado por Chezmoi + SOPS — NO editar a mano
export GITHUB_PERSONAL_ACCESS_TOKEN="$gpat"
export POSTGRES_DSN="$pdsn"
export MINIO_ACCESS_KEY="$mak"
export MINIO_SECRET_KEY="$msk"

# Compatibilidad
export GITHUB_TOKEN="\$GITHUB_PERSONAL_ACCESS_TOKEN"
export GH_TOKEN="\$GITHUB_PERSONAL_ACCESS_TOKEN"
EOF

  # Mantener compatibilidad con docker-compose: archivos de secretos para MinIO
  mkdir -p "${HOME}/.secrets/store-etl"
  printf '%s\n' "$mak" > "${HOME}/.secrets/store-etl/minio_access_key"
  printf '%s\n' "$msk" > "${HOME}/.secrets/store-etl/minio_secret_key"
  chmod 600 "${HOME}/.secrets/store-etl/minio_access_key" "${HOME}/.secrets/store-etl/minio_secret_key" 2>/dev/null || true
elif python3 -c "import yaml" 2>/dev/null; then
  python3 - "$TMP" "$OUT" << 'PYSCRIPT'
import sys, os, yaml

with open(sys.argv[1]) as f:
    data = yaml.safe_load(f)

m = (data or {}).get("mcp") or {}

def v(k):
    return (m.get(k) or "").replace("\\", "\\\\").replace('"', '\\"')

out_path = sys.argv[2]
minio_access_key = v("minio_access_key")
minio_secret_key = v("minio_secret_key")

with open(out_path, "w") as f:
    f.write("# Generado por Chezmoi + SOPS — NO editar a mano\n")
    f.write(f'export GITHUB_PERSONAL_ACCESS_TOKEN="{v("github_personal_access_token")}"\n')
    f.write(f'export POSTGRES_DSN="{v("postgres_dsn")}"\n')
    f.write(f'export MINIO_ACCESS_KEY="{minio_access_key}"\n')
    f.write(f'export MINIO_SECRET_KEY="{minio_secret_key}"\n\n')
    f.write("# Compatibilidad\n")
    f.write('export GITHUB_TOKEN="$GITHUB_PERSONAL_ACCESS_TOKEN"\n')
    f.write('export GH_TOKEN="$GITHUB_PERSONAL_ACCESS_TOKEN"\n')

# Mantener compatibilidad con docker-compose: archivos de secretos para MinIO
secrets_dir = os.path.join(os.path.expanduser("~"), ".secrets", "store-etl")
try:
    os.makedirs(secrets_dir, exist_ok=True)
    with open(os.path.join(secrets_dir, "minio_access_key"), "w") as f:
        f.write(minio_access_key + "\n")
    with open(os.path.join(secrets_dir, "minio_secret_key"), "w") as f:
        f.write(minio_secret_key + "\n")
    try:
        os.chmod(os.path.join(secrets_dir, "minio_access_key"), 0o600)
        os.chmod(os.path.join(secrets_dir, "minio_secret_key"), 0o600)
    except PermissionError:
        pass
except PermissionError:
    # Si no podemos escribir en ~/.secrets/store-etl, no fallamos:
    # los MCP ya no dependen de estos archivos, solo Docker.
    pass
PYSCRIPT
fi
exit 0
