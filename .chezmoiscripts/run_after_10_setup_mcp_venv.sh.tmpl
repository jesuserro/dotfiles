#!/usr/bin/env bash
# Crea venv neutro en ~/.config/mcp/.venv para MCPs Python.
# Se ejecuta después de apply. Requiere: python3.
set -e

VENV_DIR="$HOME/.config/mcp/.venv"
REQUIREMENTS="{{ .chezmoi.sourceDir }}/mcp/requirements.txt"

if [ ! -d "$VENV_DIR" ]; then
  python3 -m venv "$VENV_DIR"
  "$VENV_DIR/bin/pip" install --upgrade pip
fi
"$VENV_DIR/bin/pip" install -r "$REQUIREMENTS"
