# Chezmoi: gestor único activo de dotfiles relevantes (MCP + secrets + zsh stack RC files).
# RCM/rcup queda fuera del flujo activo de bootstrap (ver docs/CHEZMOI.md).
# Los patrones se aplican a TARGET paths (~/.cursor, ~/.codex, etc.), no al source.
*
!.chezmoi.toml
!.chezmoiignore
!.chezmoiscripts
!.chezmoiscripts/**
!.sops.yaml
!.cursor
!.cursor/**
!.codex
!.codex/**
!.config
!.config/**
!.secrets
!.secrets/**
!.secrets/codex.env
!.local
!.local/share
!.local/share/chezmoi
!.local/share/chezmoi/bin
!.local/share/chezmoi/bin/**
!proyectos
!proyectos/store-etl
!proyectos/store-etl/.cursor
!proyectos/store-etl/.cursor/mcp.json
!.zshrc
!.p10k.zsh
!.aliases
